# Copy to mcp/env.mcp.live (gitignored and listed in .cursorignore).
# Use a Neon read-only role — never the Render app DATABASE_URL.
#
# Setup:
# 1. Run mcp/sql/neon-mcp-readonly-role.sql in Neon SQL Editor
#    (SELECT on all app tables; password_hash and refresh token values excluded)
# 2. Create a connection string for role mcp_readonly in Neon
# 3. Copy this file to mcp/env.mcp.live and paste the URL below
# 4. Enable "app-live-readonly" in Cursor MCP settings and reload the window

MCP_MODE=readonly
DATABASE_URL=postgresql://mcp_readonly:YOUR_PASSWORD@YOUR_NEON_HOST/neondb?sslmode=require
