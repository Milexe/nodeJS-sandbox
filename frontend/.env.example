# --- Local dev (copy to .env.local) ---
VITE_API_URL=http://localhost:3000

# --- Vercel Environment Variables ---
# Production: VITE_API_URL = https://your-api.onrender.com
# Preview (PR deployments): same or a staging API URL — set under "Preview" in Vercel, not only Production
# No trailing slash; value is baked in at build time
