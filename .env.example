# --- Local dev (copy to .env) ---
ARTSEARCH_SECRET=artsearch_secret_key
PORT=3000

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/app

JWT_ACCESS_SECRET=your-access-secret-key-here
JWT_REFRESH_SECRET=your-refresh-secret-key-here
JWT_ACCESS_EXPIRES_IN=900
JWT_REFRESH_EXPIRES_IN=604800

# Comma-separated: local + production frontend
CORS_ORIGIN=http://localhost:5173,https://your-app.vercel.app
# Allow Vercel PR preview URLs (https://*.vercel.app)
CORS_ALLOW_VERCEL_PREVIEW=true

# --- Production (Render Web Service env vars) ---
# DATABASE_URL = connection string from Neon (use pooled URL if Neon offers it; Prisma works with direct URL too)
# CORS_ORIGIN = https://your-app.vercel.app  (comma-separated, no trailing slash)
# CORS_ALLOW_VERCEL_PREVIEW = true
# PORT is usually set by Render automatically; omit or use Render's PORT if required
# Do NOT set NODE_ENV=production on Render before build — npm skips devDeps and "nest: not found" fails the build.
# Build command should use: NPM_CONFIG_PRODUCTION=false npm ci && npx prisma generate && npm run build
# Render Root Directory: leave empty (not "src"). Start: npx prisma migrate deploy && node dist/src/main.js

# --- Cursor MCP live read-only (local machine only, not deployed) ---
# Copy mcp/env.mcp.live.example -> mcp/env.mcp.live and run mcp/sql/neon-mcp-readonly-role.sql in Neon.
